-- Enums para consistencia de datos
CREATE TYPE priority_type AS ENUM ('critica', 'alta', 'media', 'baja');
CREATE TYPE severity_type AS ENUM ('bloqueante', 'critica', 'alta', 'media', 'baja');
CREATE TYPE bug_status AS ENUM ('abierto', 'en_revision', 'solucionada');
CREATE TYPE execution_status AS ENUM ('pendiente', 'en_curso', 'completada', 'fallida');

-- Users (Utiliza la tabla auth.users de Supabase para login)
CREATE TABLE profiles (
  id UUID REFERENCES auth.users ON DELETE CASCADE PRIMARY KEY,
  username TEXT NOT NULL,
  rol TEXT CHECK (rol IN ('admin', 'consultor'))
);

CREATE TABLE projects (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  nombre TEXT NOT NULL,
  codigo_cliente TEXT NOT NULL
);

CREATE TABLE cases (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  custom_id TEXT UNIQUE NOT NULL, -- El ID editable + aleatorio
  project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
  prioridad priority_type,
  titulo TEXT NOT NULL,
  actor TEXT,
  descripcion_requisito TEXT,
  flujo_pasos JSONB,
  input_cliente TEXT,
  criterios_aceptacion JSONB, -- { "given": "", "when": "", "then": "", "and": "" }
  resultado_esperado TEXT,
  resultado_obtenido TEXT,
  estado_ejecucion execution_status DEFAULT 'pendiente'
);

CREATE TABLE bugs (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  custom_id TEXT UNIQUE NOT NULL,
  project_id UUID REFERENCES projects(id) ON DELETE CASCADE,
  titulo TEXT NOT NULL,
  descripcion TEXT,
  severidad severity_type,
  estado bug_status DEFAULT 'abierto'
);

-- Tabla de unión: Casos relacionados a Bugs
CREATE TABLE case_bugs (
  case_id UUID REFERENCES cases(id) ON DELETE CASCADE,
  bug_id UUID REFERENCES bugs(id) ON DELETE CASCADE,
  PRIMARY KEY (case_id, bug_id)
);

CREATE TABLE executions (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  fecha_ejecucion TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  estado execution_status,
  nombre_ciclo TEXT NOT NULL,
  notas TEXT
);

-- Unión: Ejecuciones <-> Casos
CREATE TABLE execution_cases (
  execution_id UUID REFERENCES executions(id) ON DELETE CASCADE,
  case_id UUID REFERENCES cases(id) ON DELETE CASCADE,
  PRIMARY KEY (execution_id, case_id)
);

-- Unión: Ejecuciones <-> Bugs (Para relacionar bugs encontrados durante la ejecución)
CREATE TABLE execution_bugs (
  execution_id UUID REFERENCES executions(id) ON DELETE CASCADE,
  bug_id UUID REFERENCES bugs(id) ON DELETE CASCADE,
  PRIMARY KEY (execution_id, bug_id)
);

CREATE TABLE time_logs (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  colaborador_id UUID REFERENCES profiles(id),
  project_id UUID REFERENCES projects(id),
  mes TEXT,
  fecha DATE,
  descripcion TEXT,
  horas DECIMAL(5,2)
);

CREATE TABLE objectives (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  tarea TEXT NOT NULL,
  estado BOOLEAN DEFAULT FALSE,
  deadline DATE
);

-- Histórico de Bugs (Snapshot)
CREATE TABLE bug_history (
  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
  bug_id UUID REFERENCES bugs(id),
  titulo TEXT,
  proyecto TEXT,
  fecha_cierre TIMESTAMP WITH TIME ZONE,
  estado bug_status DEFAULT 'solucionada'
);